# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าให้ตรงเครื่องจริง — ห้าม commit .env

# MySQL/MariaDB ตัวเดียวกับที่มี school_app อยู่
# user "score_app" ต้องมีสิทธิ์ ALL บน score_app และ SELECT บน school_app (ดู SQL ใน README)
DATABASE_URL="mysql://score_app:CHANGE_ME@127.0.0.1:3306/score_app"

# secret สำหรับเซ็น JWT session — สร้างด้วย: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="CHANGE_ME_TO_RANDOM_64_HEX"

# path ที่แอปทำงาน — ต้องตั้งตอน build (basePath ถูกฝังตอน build time)
#   dev: เว้นว่าง = root (http://localhost:3001/)
#   prod: /scorebright = เข้าผ่าน http://192.168.200.9/scorebright
NEXT_PUBLIC_BASE_PATH=/scorebright

# เปิด (true) เฉพาะเมื่อใช้ HTTPS จริง — LAN HTTP ต้องเป็น false ไม่งั้น cookie ไม่ถูกส่ง login พัง
COOKIE_SECURE=false

# Student API — แหล่งข้อมูลนักเรียน/ปีการศึกษา (read-only) แทนการอ่าน school_app ตรง ๆ
# ขอคีย์ (scope read:basic) จากผู้ดูแล Student API — ดู README — ห้าม commit คีย์จริง
STUDENTS_API_BASE_URL=http://192.168.200.9/students-api/v1
STUDENTS_API_KEY=sk_CHANGE_ME
